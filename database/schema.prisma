generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Province {
  code      Int        @id @db.SmallInt
  name      String     @unique @db.VarChar(100)
  districts District[]
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("provinces")
}

model District {
  id            BigInt         @id @default(autoincrement())
  pttCode       Int            @unique @map("ptt_code")
  provinceCode  Int            @map("province_code") @db.SmallInt
  name          String         @db.VarChar(100)
  province      Province       @relation(fields: [provinceCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  neighborhoods Neighborhood[]
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([provinceCode, name])
  @@index([provinceCode])
  @@map("districts")
}

model Neighborhood {
  id         BigInt   @id @default(autoincrement())
  districtId BigInt   @map("district_id")
  name       String   @db.VarChar(180)
  postalCode String   @map("postal_code") @db.Char(5)
  district   District @relation(fields: [districtId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([districtId, name, postalCode])
  @@index([districtId])
  @@index([postalCode])
  @@map("neighborhoods")
}
